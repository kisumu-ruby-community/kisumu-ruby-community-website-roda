<% unless event %>
  <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-14">
    <p class="text-foreground-muted">Event not found.</p>
  </div>
<% else %>

<section class="relative overflow-hidden bg-bg border-b border-border">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,var(--color-border)_1px,transparent_1px),linear-gradient(to_bottom,var(--color-border)_1px,transparent_1px)] bg-[size:48px_48px] opacity-40" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-14 sm:py-18">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <% if event.event_type %>
        <span class="text-xs font-semibold uppercase tracking-widest text-foreground-subtle"><%= event.event_type.capitalize %></span>
      <% end %>
      <% if event.virtual? %>
        <span class="text-xs rounded-full bg-primary-muted text-primary px-2.5 py-0.5 font-medium">Virtual</span>
      <% end %>
    </div>
    <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl font-mono mb-4"><%= event.title %></h1>
    <div class="flex flex-wrap gap-6 text-sm text-foreground-muted">
      <% if event.date %>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <%= event.date.strftime("%A, %d %B %Y · %H:%M") %>
        </span>
      <% end %>
      <% if event.location && !event.location.empty? %>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
          <%= event.location %>
        </span>
      <% end %>
      <% if event.virtual? %>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 0 0-5.656 0l-4 4a4 4 0 1 0 5.656 5.656l1.102-1.101m-.758-4.899a4 4 0 0 0 5.656 0l4-4a4 4 0 0 0-5.656-5.656l-1.1 1.1"/></svg>
          <a href="<%= event.meeting_url %>" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Join online</a>
        </span>
      <% end %>
    </div>
  </div>
</section>

<div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-14">
  <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">

    <!-- Main content -->
    <div class="lg:col-span-2 space-y-10">

      <% if event.description && !event.description.empty? %>
        <div class="prose prose-slate max-w-none text-foreground-muted leading-relaxed">
          <%= event.description %>
        </div>
      <% end %>

      <!-- Speakers -->
      <% unless speakers.empty? %>
        <div>
          <h2 class="text-xl font-bold text-foreground font-mono mb-6">Speakers</h2>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <% speakers.each do |sp| %>
              <div class="rounded-xl border border-border bg-bg p-5 flex gap-4">
                <% if sp.photo_url && !sp.photo_url.empty? %>
                  <img src="<%= sp.photo_url %>" alt="<%= sp.name %>" class="h-12 w-12 rounded-full object-cover flex-shrink-0" />
                <% else %>
                  <div class="h-12 w-12 rounded-full bg-primary-muted flex items-center justify-center text-primary font-bold flex-shrink-0">
                    <%= sp.name[0].upcase %>
                  </div>
                <% end %>
                <div>
                  <p class="font-semibold text-foreground"><%= sp.name %></p>
                  <p class="text-sm text-foreground-muted mt-1"><%= sp.bio %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>

    <!-- Sidebar -->
    <div class="space-y-4">

      <!-- RSVP -->
      <div class="rounded-xl border border-border bg-bg p-6 space-y-4">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-foreground">RSVPs</span>
          <span class="text-sm text-foreground-muted"><%= rsvp_count %> going</span>
        </div>

        <% if user_rsvpd %>
          <p class="text-sm text-success-foreground font-medium">✓ You're going!</p>
          <form action="/events/<%= event.id %>/rsvp" method="post">
            <input type="hidden" name="_method" value="delete" />
            <button type="submit" class="w-full rounded-lg border border-border px-4 py-2.5 text-sm font-medium text-foreground hover:bg-bg-subtle transition-colors">
              Cancel RSVP
            </button>
          </form>
        <% else %>
          <form action="/events/<%= event.id %>/rsvp" method="post">
            <button type="submit" class="w-full rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary-hover transition-colors">
              RSVP — I'm going
            </button>
          </form>
        <% end %>
      </div>

      <!-- Add to Google Calendar -->
      <a href="<%= event.google_calendar_url %>" target="_blank" rel="noopener noreferrer"
         class="flex items-center justify-center gap-2 w-full rounded-xl border border-border px-4 py-2.5 text-sm font-medium text-foreground hover:bg-bg-subtle transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-foreground-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Add to Google Calendar
      </a>

    </div>
  </div>
</div>

<% end %>
