<div class="max-w-xl mx-auto py-12 px-4">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Join the Community</h1>
  <p class="text-gray-500 mb-8">Become part of a growing community of Ruby and Rails developers in Kisumu, Kenya.</p>

  <form action="/join" method="post" class="space-y-5">
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
      <input type="text" id="name" name="name" required
        class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
      <input type="email" id="email" name="email" required
        class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
    </div>

    <button type="submit"
      class="w-full rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-red-700 transition-colors">
      Join Community
    </button>
  </form>
</div>
