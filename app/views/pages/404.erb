<% @title = "404 – Page Not Found" %>

<section class="flex flex-col items-center justify-center min-h-[70vh] px-4 text-center">
  <p class="font-mono text-sm font-semibold tracking-widest text-primary uppercase mb-4">404</p>

  <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-4">Page not found</h1>

  <p class="text-foreground-muted max-w-md mb-8">
    The page you're looking for doesn't exist or has been moved.
  </p>

  <a href="/"
    class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:bg-primary-hover transition-colors duration-150">
    ← Back to home
  </a>
</section>
