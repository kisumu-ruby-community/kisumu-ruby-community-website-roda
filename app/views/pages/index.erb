<section aria-labelledby="hero-heading" class="relative overflow-hidden bg-bg">
  <!-- Background grid -->
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,var(--color-border)_1px,transparent_1px),linear-gradient(to_bottom,var(--color-border)_1px,transparent_1px)] bg-[size:48px_48px] opacity-40" aria-hidden="true"></div>

  <!-- Ruby glow blob -->
  <div class="pointer-events-none absolute -top-20 right-0 h-[300px] w-[300px] rounded-full bg-primary opacity-[0.07] blur-3xl sm:-top-40 sm:h-[500px] sm:w-[500px] lg:h-[600px] lg:w-[600px]" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-28">
    <div class="grid grid-cols-1 items-center gap-10 lg:gap-14 lg:grid-cols-2">

      <!-- Left: copy -->
      <div class="space-y-6 sm:space-y-8">
        <h1 id="hero-heading" class="text-4xl font-bold leading-[1.1] tracking-tight text-foreground sm:text-5xl lg:text-7xl font-mono">
          Where Kisumu's
          <br class="hidden sm:block" />
          <span class="text-primary">Ruby</span> Developers
          <br class="hidden sm:block" />
          Thrive
        </h1>

        <p class="max-w-lg text-base leading-relaxed text-foreground-muted sm:text-lg lg:text-xl">
          Kisumu's community of Ruby and Rails developers.
          We learn together, build real things, and grow the tech
          ecosystem of Western Kenya, one gem at a time.
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          <a href="/contact" onclick="if(location.pathname=='/'){event.preventDefault();document.getElementById('contact')?.scrollIntoView({behavior:'smooth'})}" class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary-hover active:bg-primary-active transition-colors duration-150">
            Join the Community
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          
          <a
            href="/events"
            class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl border border-border bg-bg px-6 py-3 text-sm font-semibold text-foreground hover:border-border-strong hover:bg-bg-subtle transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" style="color: #CC342D"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#CC342D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-icon lucide-calendar"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            Explore Events
          </a>
        </div>
      </div>

      <!-- Right: code card -->
      <div aria-hidden="true">
        <div class="rounded-2xl border border-border bg-slate-950 shadow-2xl overflow-hidden cursor-none">
          <!-- Window chrome -->
          <div class="flex items-center gap-1.5 border-b border-white/10 px-4 py-3">
            <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/80"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/80"></span>
            <span class="ml-3 text-xs text-white/30 font-mono">kisumu_ruby.rb</span>
          </div>
          <!-- Code -->
          <pre class="overflow-x-auto p-5 text-sm leading-relaxed font-mono lg:p-6" role="presentation"><code id="typed-code"></code><span id="typed-cursor" class="inline-block h-4 w-2 bg-primary align-middle animate-pulse"></span></pre>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var segments = [
    ['# Kisumu Ruby Community',       'text-slate-500'],
    ['\n', ''],
    ['# Kisumu, Kenya - est. 2026',   'text-slate-500'],
    ['\n', ''], ['\n', ''],
    ['class',                          'text-violet-400'],
    [' ',                              'text-white'],
    ['KisumuRuby',                     'text-amber-300'],
    ['\n', ''],
    ['  ',                             'text-white'],
    ['attr_reader',                    'text-violet-400'],
    [' ',                              'text-white'],
    [':members',                       'text-sky-300'],
    [', ',                             'text-white'],
    [':city',                          'text-sky-300'],
    ['\n', ''], ['\n', ''],
    ['  ',                             'text-white'],
    ['def',                            'text-violet-400'],
    [' ',                              'text-white'],
    ['initialize',                     'text-emerald-400'],
    ['\n', ''],
    ['    ',                           'text-white'],
    ['@city',                          'text-sky-300'],
    ['    = ',                         'text-white'],
    ['"Kisumu, Kenya"',                'text-orange-300'],
    ['\n', ''],
    ['    ',                           'text-white'],
    ['@members',                       'text-sky-300'],
    [' = ',                            'text-white'],
    ['1',                              'text-amber-300'],
    ['.',                              'text-white'],
    ['+',                              'text-emerald-400'],
    ['\n', ''],
    ['    ',                           'text-white'],
    ['@stack',                         'text-sky-300'],
    ['   = [',                         'text-white'],
    [':ruby',                          'text-sky-300'],
    [', ',                             'text-white'],
    [':rails',                         'text-sky-300'],
    [']',                              'text-white'],
    ['\n', ''],
    ['  ',                             'text-white'],
    ['end',                            'text-violet-400'],
    ['\n', ''], ['\n', ''],
    ['  ',                             'text-white'],
    ['def',                            'text-violet-400'],
    [' ',                              'text-white'],
    ['join!',                          'text-emerald-400'],
    ['\n', ''],
    ['    ',                           'text-white'],
    ['"Welcome to the community!"',    'text-orange-300'],
    ['\n', ''],
    ['  ',                             'text-white'],
    ['end',                            'text-violet-400'],
    ['\n', ''],
    ['end',                            'text-violet-400'],
    ['\n', ''], ['\n', ''],
    ['# You belong here.',             'text-slate-500'],
    ['\n', ''],
    ['KisumuRuby',                     'text-amber-300'],
    ['.',                              'text-white'],
    ['new',                            'text-emerald-400'],
    ['.',                              'text-white'],
    ['join!',                          'text-emerald-400'],
    ['\n', ''],
    ['#=> "Welcome to the community!"','text-slate-500'],
  ];

  var code   = document.getElementById('typed-code');
  var cursor = document.getElementById('typed-cursor');
  var si = 0, ci = 0;
  var spans = [];

  function typeNext() {
    if (si >= segments.length) { cursor.remove(); return; }

    var seg = segments[si];

    if (seg[0] === '\n') {
      code.appendChild(document.createTextNode('\n'));
      si++; ci = 0;
      setTimeout(typeNext, 120);
      return;
    }

    if (ci < seg[0].length) {
      if (ci === 0) {
        var span = document.createElement('span');
        span.className = seg[1];
        code.appendChild(span);
        spans.push(span);
      }
      spans[spans.length - 1].textContent = seg[0].slice(0, ci + 1);
      ci++;
      setTimeout(typeNext, 40);
      return;
    }

    si++; ci = 0;
    setTimeout(typeNext, 0);
  }

  typeNext();
})();
</script>

<div id="events">
  <%= render("pages/events/index", locals: EventsService.index) %>
</div>

<div id="contact">
  <%= render("pages/contact") %>
</div>

<div id="about">
  <%= render("pages/about", locals: { title: "About", core_values: AboutService::VALUES, organizers: AboutService::ORGANIZERS }) %>
</div>
