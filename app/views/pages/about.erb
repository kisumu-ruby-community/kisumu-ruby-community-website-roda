<!-- Origin Story -->
<section aria-labelledby="about-heading" class="relative overflow-hidden bg-bg">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,var(--color-border)_1px,transparent_1px),linear-gradient(to_bottom,var(--color-border)_1px,transparent_1px)] bg-[size:48px_48px] opacity-40" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-28">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <h1 id="about-heading" class="text-4xl font-bold leading-tight tracking-tight text-foreground sm:text-5xl lg:text-6xl mb-6 font-mono">
          Built in Kisumu,<br />
          <span class="text-primary">for Kisumu.</span>
        </h1>
        <p class="text-lg leading-relaxed text-foreground-muted sm:text-xl">
          The Kisumu Ruby Community was founded in 2026 by a group of Ruby developers who
          wanted more than online tutorials. They wanted a local space to learn, build, and grow
          together. What started as informal meetups aims to grow into a thriving community of
          engineers, students, and entrepreneurs united by a love for Ruby and Rails.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-foreground-muted sm:text-xl">
          Our mission is to grow the Ruby ecosystem in Western Kenya by creating opportunities
          for developers at every level to connect, collaborate, and ship real software.
        </p>
      </div>

      <!-- Right: mission card -->
      <div class="rounded-2xl border border-border bg-slate-950 p-8 lg:p-10" aria-hidden="true">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4 font-mono"># mission.rb</p>
        <blockquote class="text-2xl font-semibold leading-snug text-white font-mono">
          "Learn together.<br /><br />Build real things.<br /><br />Grow the ecosystem."
        </blockquote>
        <p class="mt-6 text-sm text-slate-400 font-mono">- Kisumu Ruby Community, est. 2026</p>
      </div>

    </div>
  </div>
</section>

<!-- Core Values -->
<section aria-labelledby="values-heading" class="bg-bg-subtle border-t border-border">
  <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <h2 id="values-heading" class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl mb-10 font-mono">Our Values</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% core_values.each do |value| %>
        <div class="rounded-xl border border-border bg-bg p-6">
          <h3 class="text-base font-semibold text-foreground mb-2"><%= value[:title] %></h3>
          <p class="text-sm leading-relaxed text-foreground-muted"><%= value[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Leadership -->
<section aria-labelledby="team-heading" class="bg-bg border-t border-border">
  <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <h2 id="team-heading" class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl mb-10 font-mono">Leadership</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% organizers.each do |person| %>
        <div class="rounded-xl border border-border bg-bg p-6 flex flex-col gap-4">
          <div class="h-14 w-14 rounded-full bg-primary-muted flex items-center justify-center text-primary font-bold text-lg" aria-hidden="true">
            <%= person[:initials] %>
          </div>
          <div>
            <p class="font-semibold text-foreground"><%= person[:name] %></p>
            <p class="text-sm text-primary"><%= person[:role] %></p>
          </div>
          <p class="text-sm leading-relaxed text-foreground-muted flex-1"><%= person[:bio] %></p>
          <% if person[:github] || person[:linkedin] || person[:twitter] %>
            <div class="flex gap-3">
              <% if person[:github] %>
                <a href="<%= person[:github] %>" target="_blank" rel="noopener noreferrer" class="text-foreground-muted hover:text-foreground transition-colors" aria-label="GitHub profile">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
                </a>
              <% end %>
              <% if person[:linkedin] %>
                <a href="<%= person[:linkedin] %>" target="_blank" rel="noopener noreferrer" class="text-foreground-muted hover:text-foreground transition-colors" aria-label="LinkedIn profile">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              <% end %>
              <% if person[:twitter] %>
                <a href="<%= person[:twitter] %>" target="_blank" rel="noopener noreferrer" class="text-foreground-muted hover:text-foreground transition-colors" aria-label="Twitter profile">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
