<div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-foreground font-mono">Events</h1>
    <a href="/admin/events/new" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary-hover transition-colors">
      + New Event
    </a>
  </div>

  <% if events.empty? %>
    <p class="text-foreground-muted">No events yet.</p>
  <% else %>

    <!-- Mobile: cards -->
    <div class="lg:hidden space-y-3">
      <% events.each do |event| %>
        <div class="rounded-xl border border-border bg-bg p-4 space-y-3">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-medium text-foreground"><%= event.title %></p>
              <p class="text-xs text-foreground-muted mt-0.5"><%= event.date&.strftime("%d %b %Y, %H:%M") || "No date" %></p>
            </div>
            <span class="shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
              <%= event.status == 'published' ? 'bg-success-bg text-success-foreground' : 'bg-bg-muted text-foreground-muted' %>">
              <%= event.status&.capitalize %>
            </span>
          </div>
          <p class="text-xs text-foreground-muted"><%= event.event_type&.capitalize || "-" %></p>
          <div class="flex items-center gap-4 pt-1 border-t border-border">
            <a href="/admin/events/<%= event.id %>/edit" class="text-sm text-primary hover:underline">Edit</a>
            <form action="/admin/events/<%= event.id %>/delete" method="post" class="delete-form">
              <button type="button" class="delete-btn text-sm text-red-600 hover:underline cursor-pointer" data-title="<%= event.title %>">Delete</button>
            </form>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Desktop: table -->
    <div class="hidden lg:block rounded-xl border border-border overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-bg-subtle border-b border-border">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-foreground">Title</th>
            <th class="px-4 py-3 text-left font-semibold text-foreground">Date</th>
            <th class="px-4 py-3 text-left font-semibold text-foreground">Type</th>
            <th class="px-4 py-3 text-left font-semibold text-foreground">Status</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% events.each do |event| %>
            <tr class="bg-bg hover:bg-bg-subtle transition-colors">
              <td class="px-4 py-3 font-medium text-foreground"><%= event.title %></td>
              <td class="px-4 py-3 text-foreground-muted"><%= event.date&.strftime("%d %b %Y, %H:%M") || "-" %></td>
              <td class="px-4 py-3 text-foreground-muted"><%= event.event_type&.capitalize || "-" %></td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                  <%= event.status == 'published' ? 'bg-success-bg text-success-foreground' : 'bg-bg-muted text-foreground-muted' %>">
                  <%= event.status&.capitalize %>
                </span>
              </td>
              <td class="px-4 py-3 text-right space-x-2">
                <a href="/admin/events/<%= event.id %>/edit" class="text-sm text-primary hover:underline">Edit</a>
                <form action="/admin/events/<%= event.id %>/delete" method="post" class="inline delete-form">
                  <button type="button" class="delete-btn text-sm text-red-600 hover:underline cursor-pointer" data-title="<%= event.title %>">Delete</button>
                </form>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% end %>
</div>

<script>
document.querySelectorAll('.delete-btn').forEach(function (btn) {
  btn.addEventListener('click', function () {
    var form  = btn.closest('.delete-form');
    var title = btn.dataset.title;
    window.__confirm('Delete "' + title + '"? This cannot be undone.').then(function (ok) {
      if (ok) form.submit();
    });
  });
});
</script>
