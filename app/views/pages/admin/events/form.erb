<!-- Page header -->
<section class="relative overflow-hidden bg-bg border-b border-border">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,var(--color-border)_1px,transparent_1px),linear-gradient(to_bottom,var(--color-border)_1px,transparent_1px)] bg-[size:48px_48px] opacity-40" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center gap-4">
      <a href="/admin/events" class="inline-flex items-center gap-1.5 text-sm text-foreground-muted hover:text-foreground transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
        Back
      </a>
      <h1 class="text-2xl font-bold text-foreground font-mono"><%= event ? "Edit Event" : "New Event" %></h1>
    </div>
  </div>
</section>

<div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 py-10">

  <% unless errors.empty? %>
    <div class="rounded-xl border border-error-border bg-error-bg px-5 py-4 text-sm text-error-foreground mb-8">
      <ul class="list-disc list-inside space-y-1">
        <% errors.each do |_, msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <form action="<%= event ? "/admin/events/#{event.id}" : "/admin/events" %>" method="post" enctype="multipart/form-data">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-3 lg:gap-16">

      <!-- Left: main fields -->
      <div class="lg:col-span-2 space-y-5">

        <div>
          <label class="block text-sm font-medium text-foreground mb-1.5">Title <span class="text-primary">*</span></label>
          <input type="text" name="title" value="<%= event&.title %>" required
            class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-foreground mb-1.5">Start Date &amp; Time <span class="text-primary">*</span></label>
            <input type="datetime-local" name="date" value="<%= event&.date&.strftime("%Y-%m-%dT%H:%M") %>" required
              class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium text-foreground mb-1.5">End Date &amp; Time</label>
            <input type="datetime-local" name="end_date" value="<%= event&.end_date&.strftime("%Y-%m-%dT%H:%M") %>"
              class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-1.5">Location</label>
          <input type="text" name="location" value="<%= event&.location %>" placeholder="e.g. Zone01 Kisumu, or leave blank for virtual"
            class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-1.5">Meeting URL <span class="text-foreground-muted text-xs">(virtual events)</span></label>
          <input type="url" name="meeting_url" value="<%= event&.meeting_url %>" placeholder="https://meet.google.com/..."
            class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-1.5">Description</label>
          <textarea name="description" rows="7"
            class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary resize-none"><%= event&.description %></textarea>
        </div>

        <!-- Speakers -->
        <div>
          <div class="flex items-center justify-between mb-3">
            <label class="text-sm font-medium text-foreground">Speakers</label>
            <button type="button" id="add-speaker" class="text-sm text-primary hover:underline">+ Add Speaker</button>
          </div>
          <div id="speakers-list" class="space-y-4">
            <% (event&.speakers || []).each_with_index do |sp, i| %>
              <div class="speaker-entry rounded-xl border border-border p-4 space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-foreground">Speaker <%= i + 1 %></span>
                  <button type="button" class="remove-speaker text-xs text-red-600 hover:underline">Remove</button>
                </div>
                <input type="text" name="speakers[<%= i %>][name]" value="<%= sp.name %>" placeholder="Name"
                  class="w-full rounded-lg border border-border bg-bg px-3.5 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
                <div>
                  <label class="block text-xs text-foreground-muted mb-1">Photo</label>
                  <div class="img-drop-zone relative rounded-xl border-2 border-dashed border-border hover:border-primary/50 transition-colors cursor-pointer overflow-hidden"
                       data-input-name="speakers[<%= i %>][photo_file]">
                    <% if sp.photo_url && !sp.photo_url.empty? %>
                      <div class="img-preview">
                        <img src="<%= sp.photo_url %>" alt="<%= sp.name %>" class="w-full aspect-video object-cover" />
                        <button type="button" class="img-remove absolute top-2 right-2 rounded-full bg-bg/80 border border-border p-1.5 hover:bg-bg transition-colors" aria-label="Remove image">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                      </div>
                    <% end %>
                    <div class="img-placeholder flex flex-col items-center justify-center py-8 px-4 text-center <%= sp.photo_url && !sp.photo_url.empty? ? 'hidden' : '' %>">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-foreground-muted mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
                      </svg>
                      <span class="text-sm text-foreground-muted">Drop photo here or <span class="text-primary font-medium">browse</span></span>
                      <span class="text-xs text-foreground-muted mt-1">JPG, PNG, GIF or WebP · Max 5 MB</span>
                    </div>
                    <input type="file" name="speakers[<%= i %>][photo_file]" accept="image/jpeg,image/png,image/gif,image/webp"
                      class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                  </div>
                  <button type="button" class="url-toggle mt-2 text-xs text-foreground-muted hover:text-foreground transition-colors">Use URL instead</button>
                  <input type="text" name="speakers[<%= i %>][photo_url]" value="" placeholder="https://example.com/photo.jpg"
                    class="url-input mt-1.5 w-full rounded-lg border border-border bg-bg px-3.5 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary hidden" />
                </div>
                <textarea name="speakers[<%= i %>][bio]" rows="2" placeholder="Short bio"
                  class="w-full rounded-lg border border-border bg-bg px-3.5 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary resize-none"><%= sp.bio %></textarea>
              </div>
            <% end %>
          </div>
        </div>

      </div>

      <!-- Right: settings sidebar -->
      <div class="space-y-5">

        <div class="rounded-xl border border-border bg-bg-subtle p-5 space-y-5">
          <h2 class="text-sm font-semibold text-foreground font-mono">Settings</h2>

          <!-- Cover image upload -->
          <div>
            <label class="block text-sm font-medium text-foreground mb-1.5">Poster / Cover Image</label>
            <div id="cover-drop-zone" class="img-drop-zone relative rounded-2xl border-2 border-dashed border-border hover:border-primary/50 transition-colors cursor-pointer overflow-hidden"
                 data-input-name="cover_image_file">
              <% if event&.poster? %>
                <div class="img-preview">
                  <img src="<%= event.cover_image %>" alt="Current poster" class="w-full aspect-video object-cover" />
                  <button type="button" class="img-remove absolute top-2 right-2 rounded-full bg-bg/80 border border-border p-1.5 hover:bg-bg transition-colors" aria-label="Remove image">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                  </button>
                </div>
              <% end %>
              <div class="img-placeholder flex flex-col items-center justify-center py-8 px-4 text-center <%= event&.poster? ? 'hidden' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-foreground-muted mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
                </svg>
                <span class="text-sm text-foreground-muted">Drop poster here or <span class="text-primary font-medium">browse</span></span>
                <span class="text-xs text-foreground-muted mt-1">JPG, PNG, GIF or WebP · Max 5 MB</span>
              </div>
              <input type="file" name="cover_image_file" accept="image/jpeg,image/png,image/gif,image/webp"
                class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
            </div>
            <button type="button" class="url-toggle mt-2 text-xs text-foreground-muted hover:text-foreground transition-colors">Use URL instead</button>
            <input type="url" name="cover_image" value="" placeholder="https://example.com/poster.jpg"
              class="url-input mt-1.5 w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary hidden" />
          </div>

          <div>
            <label class="block text-sm font-medium text-foreground mb-1.5">Event Type</label>
            <select name="event_type" class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary">
              <option value="">Select type</option>
              <% %w[workshop talk hackathon social].each do |t| %>
                <option value="<%= t %>" <%= event&.event_type == t ? "selected" : "" %>><%= t.capitalize %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-foreground mb-1.5">Status</label>
            <select name="status" class="w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary">
              <% %w[draft published archived].each do |s| %>
                <option value="<%= s %>" <%= (event&.status || "draft") == s ? "selected" : "" %>><%= s.capitalize %></option>
              <% end %>
            </select>
          </div>
        </div>

        <div class="flex flex-col gap-3">
          <button type="submit" data-loading="Saving..." class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary-hover transition-colors cursor-pointer">
            <%= event ? "Save Changes" : "Create Event" %>
          </button>
          <a href="/admin/events" class="w-full inline-flex items-center justify-center rounded-xl border border-border px-5 py-2.5 text-sm font-medium text-foreground hover:bg-bg-subtle transition-colors">Cancel</a>
        </div>

      </div>
    </div>
  </form>
</div>

<script>
(function () {
  // --- Speakers dynamic add/remove ---
  var list  = document.getElementById('speakers-list');
  var count = list.querySelectorAll('.speaker-entry').length;

  function speakerPhotoHTML(i) {
    return '<div>' +
      '<label class="block text-xs text-foreground-muted mb-1">Photo</label>' +
      '<div class="img-drop-zone relative rounded-xl border-2 border-dashed border-border hover:border-primary/50 transition-colors cursor-pointer overflow-hidden" data-input-name="speakers[' + i + '][photo_file]">' +
        '<div class="img-placeholder flex flex-col items-center justify-center py-8 px-4 text-center">' +
          '<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-foreground-muted mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>' +
          '<span class="text-sm text-foreground-muted">Drop photo here or <span class="text-primary font-medium">browse</span></span>' +
          '<span class="text-xs text-foreground-muted mt-1">JPG, PNG, GIF or WebP · Max 5 MB</span>' +
        '</div>' +
        '<input type="file" name="speakers[' + i + '][photo_file]" accept="image/jpeg,image/png,image/gif,image/webp" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />' +
      '</div>' +
      '<button type="button" class="url-toggle mt-2 text-xs text-foreground-muted hover:text-foreground transition-colors">Use URL instead</button>' +
      '<input type="text" name="speakers[' + i + '][photo_url]" placeholder="https://example.com/photo.jpg" class="url-input mt-1.5 w-full rounded-lg border border-border bg-bg px-3.5 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary hidden" />' +
    '</div>';
  }

  document.getElementById('add-speaker').addEventListener('click', function () {
    var i   = count++;
    var div = document.createElement('div');
    div.className = 'speaker-entry rounded-xl border border-border p-4 space-y-3';
    div.innerHTML =
      '<div class="flex justify-between items-center"><span class="text-sm font-medium text-foreground">Speaker ' + (i + 1) + '</span><button type="button" class="remove-speaker text-xs text-red-600 hover:underline">Remove</button></div>' +
      '<input type="text" name="speakers[' + i + '][name]" placeholder="Name" class="w-full rounded-lg border border-border bg-bg px-3.5 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />' +
      speakerPhotoHTML(i) +
      '<textarea name="speakers[' + i + '][bio]" rows="2" placeholder="Short bio" class="w-full rounded-lg border border-border bg-bg px-3.5 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary resize-none"></textarea>';
    list.appendChild(div);
    initDropZones(div);
  });

  list.addEventListener('click', function (e) {
    if (e.target.classList.contains('remove-speaker')) {
      e.target.closest('.speaker-entry').remove();
    }
  });

  // --- Drop-zone & preview logic ---
  function initDropZones(root) {
    root.querySelectorAll('.img-drop-zone').forEach(function (zone) {
      var fileInput   = zone.querySelector('input[type="file"]');
      var placeholder = zone.querySelector('.img-placeholder');

      // Drag highlight
      zone.addEventListener('dragover', function (e) { e.preventDefault(); zone.classList.add('border-primary'); });
      zone.addEventListener('dragleave', function ()  { zone.classList.remove('border-primary'); });
      zone.addEventListener('drop', function (e) {
        e.preventDefault();
        zone.classList.remove('border-primary');
        if (e.dataTransfer.files.length) {
          fileInput.files = e.dataTransfer.files;
          showPreview(zone, e.dataTransfer.files[0]);
        }
      });

      // File chosen via browse
      fileInput.addEventListener('change', function () {
        if (fileInput.files.length) showPreview(zone, fileInput.files[0]);
      });
    });

    // URL toggle buttons
    root.querySelectorAll('.url-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var input = btn.parentElement.querySelector('.url-input') || btn.nextElementSibling;
        var isHidden = input.classList.contains('hidden');
        input.classList.toggle('hidden');
        btn.textContent = isHidden ? 'Hide URL field' : 'Use URL instead';
      });
    });

    // Remove buttons on existing previews
    root.querySelectorAll('.img-remove').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        var zone = btn.closest('.img-drop-zone');
        clearPreview(zone);
      });
    });
  }

  function showPreview(zone, file) {
    if (!file || !file.type.startsWith('image/')) return;
    var reader = new FileReader();
    reader.onload = function (e) {
      var old = zone.querySelector('.img-preview');
      if (old) old.remove();

      var placeholder = zone.querySelector('.img-placeholder');
      placeholder.classList.add('hidden');

      var wrap = document.createElement('div');
      wrap.className = 'img-preview';
      wrap.innerHTML =
        '<img src="' + e.target.result + '" alt="Preview" class="w-full aspect-video object-cover" />' +
        '<button type="button" class="img-remove absolute top-2 right-2 p-1.5 rounded-full bg-bg/80 border border-border hover:bg-bg transition-colors" aria-label="Remove image">' +
          '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>' +
        '</button>';
      zone.insertBefore(wrap, placeholder);

      wrap.querySelector('.img-remove').addEventListener('click', function (ev) {
        ev.preventDefault();
        ev.stopPropagation();
        clearPreview(zone);
      });
    };
    reader.readAsDataURL(file);
  }

  function clearPreview(zone) {
    var preview = zone.querySelector('.img-preview');
    if (preview) preview.remove();
    zone.querySelector('.img-placeholder').classList.remove('hidden');
    var fileInput = zone.querySelector('input[type="file"]');
    fileInput.value = '';
  }

  // Init all zones on page load
  initDropZones(document);
})();
</script>
